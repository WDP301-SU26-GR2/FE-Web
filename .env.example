# ─── API ─────────────────────────────────────────────────────────────────────
# URL base của backend API. Khi BE chưa sẵn sàng, để trống và bật ENABLE_MOCK.
VITE_API_URL=

# ─── Mock ────────────────────────────────────────────────────────────────────
# "true" = MSW mock server bật trong dev (FE chạy độc lập, không cần BE).
# "false" = gọi API thật qua VITE_API_URL.
VITE_ENABLE_MOCK=true

# ─── App ─────────────────────────────────────────────────────────────────────
# development | staging | production
VITE_APP_ENV=development
