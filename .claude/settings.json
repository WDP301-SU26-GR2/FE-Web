{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm start)",
      "Bash(npm run start:csr)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run prettier)",
      "Bash(npm run prettier:fix)",
      "Bash(npm run orval)",
      "Bash(npm run orval:watch)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)"
    ],
    "deny": [
      "Edit(app/api/model/**)",
      "Edit(app/api/operations/**)",
      "Write(app/api/model/**)",
      "Write(app/api/operations/**)",
      "Write(tailwind.config.js)",
      "Write(tailwind.config.ts)",
      "Write(./**/*react-router-dom*)",
      "Bash(npm install react-router-dom*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=process.env.CLAUDE_TOOL_PATH||'';if(/\\\\.(ts|tsx|js|jsx)$/.test(p))process.exit(0);process.exit(0)\""
          }
        ]
      }
    ]
  }
}
